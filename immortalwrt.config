# ===========================================
# 基础目标配置 (必需)
# ===========================================
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y
CONFIG_GRUB_TIMEOUT="0"
CONFIG_GRUB_TITLE="Wei"
CONFIG_GRUB_EFI_IMAGES=y

# ===========================================
# 虚拟机镜像格式 (x86/64 虚拟机专用)
# 生成 combined-efi.img.gz 需要以下配置
# ===========================================
# CONFIG_ISO_IMAGES is not set
# CONFIG_QCOW2_IMAGES is not set
# CONFIG_VHDX_IMAGES is not set
# CONFIG_VMDK_IMAGES is not set
# CONFIG_VDI_IMAGES is not set

# ===========================================
# 文件系统配置 (必需 - squashfs 用于生成 combined 镜像)
# 保留 EXT4FS 和 PARTSIZE=400 用于 LXC 容器支持
# ===========================================
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_ROOTFS_EXT4FS=y
CONFIG_TARGET_ROOTFS_PARTSIZE=400

# ===========================================
# 编译优化选项 (推荐)
# ===========================================
CONFIG_AUTOREMOVE=y
CONFIG_REPRODUCIBLE_DEBUG_INFO=y

# ===========================================
# 核心网络模块 (必需 - 防火墙/NAT/转发)
# ===========================================
CONFIG_PACKAGE_firewall=y
CONFIG_PACKAGE_iptables-nft=y
CONFIG_PACKAGE_xtables-nft=y
CONFIG_PACKAGE_kmod-ipt-core=y
CONFIG_PACKAGE_kmod-ipt-conntrack=y
CONFIG_PACKAGE_kmod-ipt-nat=y
CONFIG_PACKAGE_kmod-ipt-nat6=y
CONFIG_PACKAGE_kmod-ipt-offload=y
CONFIG_PACKAGE_kmod-ipt-raw=y
CONFIG_PACKAGE_kmod-ipt-extra=y
CONFIG_PACKAGE_kmod-ipt-fullconenat=y
CONFIG_PACKAGE_kmod-ipt-tproxy=y
CONFIG_PACKAGE_kmod-ipt-ipset=y
CONFIG_PACKAGE_kmod-ip6tables=y
CONFIG_PACKAGE_kmod-nf-ipt=y
CONFIG_PACKAGE_kmod-nf-ipt6=y
CONFIG_PACKAGE_kmod-nf-nat6=y
CONFIG_PACKAGE_kmod-nf-tproxy=y
CONFIG_PACKAGE_kmod-nf-socket=y
CONFIG_PACKAGE_kmod-nft-compat=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-nft-socket=y
CONFIG_PACKAGE_ip6tables-mod-nat=y
CONFIG_PACKAGE_iptables-mod-fullconenat=y
CONFIG_PACKAGE_iptables-mod-tproxy=y
CONFIG_PACKAGE_iptables-mod-extra=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_ipset=y
CONFIG_PACKAGE_libip4tc=y
CONFIG_PACKAGE_libip6tc=y
CONFIG_PACKAGE_libipset=y
CONFIG_PACKAGE_libiptext=y
CONFIG_PACKAGE_libiptext6=y
CONFIG_PACKAGE_libiptext-nft=y
CONFIG_PACKAGE_libxtables=y

# ===========================================
# 基础网络驱动 (x86/64 虚拟机必需)
# ===========================================
CONFIG_PACKAGE_kmod-e1000=y
CONFIG_PACKAGE_kmod-virtio-net=y
CONFIG_PACKAGE_kmod-vmxnet3=y

# ===========================================
# DNS/DHCP 服务 (必需)
# ===========================================
CONFIG_PACKAGE_dnsmasq=y
CONFIG_PACKAGE_dnsmasq_full_ipset=y
CONFIG_PACKAGE_dnsmasq_full_dhcpv6=y
CONFIG_PACKAGE_resolveip=y

# ===========================================
# IPv6 支持 (推荐)
# ===========================================
CONFIG_PACKAGE_kmod-nf-nat6=y
CONFIG_PACKAGE_ip6tables-mod-nat=y

# ===========================================
# 代理工具核心 (主力：HomeProxy + MosDNS，备用：Nikki)
# OpenClash 已移除以节省空间
# ===========================================
CONFIG_PACKAGE_homeproxy=y
CONFIG_PACKAGE_luci-app-homeproxy=y
CONFIG_PACKAGE_luci-i18n-homeproxy-zh-cn=y
CONFIG_PACKAGE_mosdns=y
CONFIG_PACKAGE_luci-app-mosdns=y
CONFIG_PACKAGE_luci-i18n-mosdns-zh-cn=y
# CONFIG_PACKAGE_openclash is not set
# CONFIG_PACKAGE_luci-app-openclash is not set
CONFIG_PACKAGE_nikki=y
CONFIG_PACKAGE_luci-app-nikki=y
CONFIG_PACKAGE_luci-i18n-nikki-zh-cn=y
CONFIG_PACKAGE_chinadns-ng=y
CONFIG_PACKAGE_xray-core=y
CONFIG_PACKAGE_v2ray-geoip=y
CONFIG_PACKAGE_v2ray-geosite=y
CONFIG_PACKAGE_v2dat=y
CONFIG_PACKAGE_dns2socks=y
CONFIG_PACKAGE_dns2tcp=y
CONFIG_PACKAGE_microsocks=y
CONFIG_PACKAGE_simple-obfs=y
CONFIG_PACKAGE_tcping=y

# ===========================================
# ZeroTier/内网穿透 (可选)
# ===========================================
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_luci-app-zerotier=y
CONFIG_PACKAGE_luci-i18n-zerotier-zh-cn=y
# CONFIG_PACKAGE_luci-app-unblockneteasemusic is not set

# ===========================================
# UPnP/DLNA (旁路由通常不需要)
# ===========================================
# CONFIG_PACKAGE_luci-app-upnp is not set
# CONFIG_PACKAGE_luci-i18n-upnp-zh-cn is not set
# CONFIG_PACKAGE_miniupnpd-nftables is not set

# ===========================================
# KMS 激活服务 (可选)
# ===========================================
CONFIG_PACKAGE_luci-app-vlmcsd=y

# ===========================================
# TTYD 终端 (推荐)
# ===========================================
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y

# ===========================================
# 主题与界面 (可选 - 建议只保留一个主题)
# ===========================================
CONFIG_PACKAGE_luci-theme-argon=y
# CONFIG_PACKAGE_luci-theme-design is not set
CONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_luci-i18n-argon-config-zh-cn=y

# ===========================================
# 加密与安全库 (必需 - TLS/SSL 依赖)
# ===========================================
CONFIG_PACKAGE_libmbedtls=y
CONFIG_MBEDTLS_AES_C=y
CONFIG_MBEDTLS_CMAC_C=y
CONFIG_MBEDTLS_GCM_C=y
CONFIG_MBEDTLS_ECP_DP_CURVE25519_ENABLED=y
CONFIG_MBEDTLS_ECP_DP_SECP256R1_ENABLED=y
CONFIG_MBEDTLS_ECP_DP_SECP384R1_ENABLED=y
CONFIG_MBEDTLS_KEY_EXCHANGE_ECDHE_RSA_ENABLED=y
CONFIG_MBEDTLS_KEY_EXCHANGE_ECDHE_ECDSA_ENABLED=y
CONFIG_PACKAGE_libsodium=y
CONFIG_LIBSODIUM_MINIMAL=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_libcurl=y
CONFIG_LIBCURL_OPENSSL=y
CONFIG_LIBCURL_NGHTTP2=y
CONFIG_PACKAGE_libnghttp2=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y

# ===========================================
# IPsec/StrongSwan (可选 - VPN 需求，旁路由通常不需要)
# ===========================================
# CONFIG_PACKAGE_strongswan-full is not set
# CONFIG_PACKAGE_strongswan-swanctl is not set

# ===========================================
# SNMP 监控 (可选，旁路由通常不需要)
# ===========================================
# CONFIG_PACKAGE_libnetsnmp is not set
# CONFIG_PACKAGE_snmpd is not set

# ===========================================
# FUSE/存储 (可选)
# ===========================================
CONFIG_PACKAGE_fuse-utils=y
CONFIG_PACKAGE_kmod-fuse=y
CONFIG_PACKAGE_libfuse=y

# ===========================================
# 系统工具 (推荐 - 精简版)
# ===========================================
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_coreutils=y
CONFIG_PACKAGE_coreutils-base64=y
CONFIG_PACKAGE_coreutils-nohup=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_unzip=y
CONFIG_PACKAGE_xz=y
CONFIG_PACKAGE_xz-utils=y
CONFIG_PACKAGE_liblzma=y
CONFIG_PACKAGE_zlib=y
CONFIG_PACKAGE_libreadline=y
CONFIG_PACKAGE_libelf=y
CONFIG_PACKAGE_libbpf=y
CONFIG_PACKAGE_kmod-hwmon-core=y

# ===========================================
# Node.js/Ruby 环境 (已移除 - 占用空间大)
# 如后续需要安装 unblockneteasemusic 等依赖 Node.js 的插件，
# 可手动安装 ipk 时自动拉取依赖，或取消下方注释预先编译
# ===========================================
# CONFIG_PACKAGE_node108 is not set
# CONFIG_PACKAGE_ruby is not set
# CONFIG_PACKAGE_libruby is not set
# CONFIG_PACKAGE_ruby-yaml is not set
CONFIG_PACKAGE_lua-neturl=y
CONFIG_PACKAGE_libuci-lua=y

# ===========================================
# 其他库依赖
# ===========================================
CONFIG_PACKAGE_libcares=y
CONFIG_PACKAGE_libev=y
CONFIG_PACKAGE_libpcre=y
CONFIG_PACKAGE_libpcre2=y
CONFIG_PACKAGE_libudns=y
CONFIG_PACKAGE_libyaml=y
CONFIG_PACKAGE_libcap=y
CONFIG_PACKAGE_libcap-ng=y
CONFIG_PACKAGE_libcap-bin=y
CONFIG_PACKAGE_libcap-bin-capsh-shell="/bin/sh"
# CONFIG_PACKAGE_libpci is not set
# CONFIG_PACKAGE_libiwinfo-lua is not set
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_zoneinfo-asia=y
CONFIG_PACKAGE_zoneinfo-core=y

# ===========================================
# 已禁用的包 (注释掉以节省空间)
# ===========================================
# CONFIG_PACKAGE_luci-app-mihomo is not set
# CONFIG_PACKAGE_mihomo is not set
# CONFIG_PACKAGE_luci-app-ssr-plus is not set
# CONFIG_PACKAGE_shadowsocks-libev-* is not set
# CONFIG_PACKAGE_shadowsocksr-libev-* is not set
# CONFIG_PACKAGE_softethervpn5-* is not set
